// STATE
// ─────────────────────────────────────────
const state = {
  current: null,
  results: {},    // id → {answers: {...lineIdx: token}, revealed: bool, checked: bool, correct: bool}
  openDropdown: null,
};

// ─────────────────────────────────────────
// HELPERS
// ─────────────────────────────────────────
function getLevelInfo(lvl) {
  const map = {
    easy:  { label:'Muy fácil',  cls:'badge-easy',  color:'var(--green)'  },
    med:   { label:'Intermedio', cls:'badge-med',   color:'var(--yellow)' },
    hard:  { label:'Difícil',    cls:'badge-hard',  color:'var(--red)'    },
    vhard: { label:'Muy difícil',cls:'badge-vhard', color:'var(--purple)' },
  };
  return map[lvl];
}

function getStats() {
  let ok=0, total=0;
  Object.values(state.results).forEach(r => {
    if (r.checked || r.revealed) {
      total++;
      if (r.correct) ok++;
    }
  });
  return {ok, total, pct: total ? Math.round(ok/total*100) : 0};
}

function updateStats() {
  const s = getStats();
  document.getElementById('st-ok').textContent = s.ok;
  document.getElementById('st-total').textContent = s.total;
  document.getElementById('st-pct').textContent = s.pct+'%';
}

// ─────────────────────────────────────────
// SIDEBAR
// ─────────────────────────────────────────
function buildSidebar() {
  const aside = document.getElementById('sidebar');
  const levels = [
    { key:'easy',  label:'Muy Fáciles',  ids: EXERCISES.filter(e=>e.level==='easy').map(e=>e.id)  },
    { key:'med',   label:'Intermedios',  ids: EXERCISES.filter(e=>e.level==='med').map(e=>e.id)   },
    { key:'hard',  label:'Difíciles',    ids: EXERCISES.filter(e=>e.level==='hard').map(e=>e.id)  },
    { key:'vhard', label:'Muy Difíciles',ids: EXERCISES.filter(e=>e.level==='vhard').map(e=>e.id) },
  ];
  let html = '';
  levels.forEach(({key, label, ids}) => {
    const info = getLevelInfo(key);
    html += `<div class="sidebar-section">
      <div class="sidebar-title"><span class="level-badge ${info.cls}">${label}</span></div>`;
    ids.forEach(id => {
      const ex = EXERCISES.find(e=>e.id===id);
      html += `<button class="ex-btn" id="btn-ex-${id}" onclick="loadExercise(${id})">
        <span style="font-size:.7rem;color:var(--muted)">#${String(id).padStart(2,'0')}</span>
        <span style="flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${ex.title}</span>
      </button>`;
    });
    html += '</div>';
  });
  aside.innerHTML = html;
}

function updateSidebarBtn(id) {
  const btn = document.getElementById(`btn-ex-${id}`);
  if (!btn) return;
  btn.className = 'ex-btn';
  if (id === state.current) btn.classList.add('active');
  const r = state.results[id];
  if (r) {
    if (r.revealed) btn.classList.add('revealed');
    else if (r.checked && r.correct) btn.classList.add('done-ok');
    else if (r.checked && !r.correct) btn.classList.add('done-fail');
  }
}

// ─────────────────────────────────────────
// SYNTAX HIGHLIGHT (simple)
// ─────────────────────────────────────────
function highlight(code) {
  const keywords = ['for','while','if','else','return','int','void','bool','char','true','false','continue','do','break'];
  let h = code
    .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  // comments
  h = h.replace(/(\/\/[^\n]*)/g,'<span class="cmt">$1</span>');
  // strings
  h = h.replace(/(".*?")/g,'<span class="cmt">$1</span>');
  // numbers (standalone)
  h = h.replace(/\b(\d+)\b/g,'<span class="num">$1</span>');
  // keywords
  keywords.forEach(kw => {
    h = h.replace(new RegExp(`\\b(${kw})\\b`,'g'),'<span class="kw">$1</span>');
  });
  return h;
}

// ─────────────────────────────────────────
// LOAD EXERCISE
// ─────────────────────────────────────────
function loadExercise(id) {
  // close any open dropdown
  closeAllDropdowns();

  const prev = state.current;
  state.current = id;
  if (prev) updateSidebarBtn(prev);
  updateSidebarBtn(id);

  document.getElementById('welcome').style.display = 'none';
  document.getElementById('exercise-view').style.display = 'block';

  if (!state.results[id]) {
    state.results[id] = { answers: {}, revealed: false, checked: false, correct: false };
  }

  renderExercise(id);
}

function renderExercise(id) {
  const ex = EXERCISES.find(e=>e.id===id);
  const r = state.results[id];
  const info = getLevelInfo(ex.level);
  const answerable = ex.lines.filter(l => l.cx !== null);
  const answered = Object.keys(r.answers).length;
  const pctDone = answerable.length ? Math.round(answered/answerable.length*100) : 0;

  let html = `
  <div class="ex-header">
    <div class="ex-meta">
      <span class="ex-num">Ejercicio #${String(ex.id).padStart(2,'0')}</span>
      <span class="level-badge ${info.cls}">${info.label}</span>
      <span class="ex-pts">${ex.pts} punto${ex.pts!==1?'s':''}</span>
    </div>
    <div class="ex-title">${ex.title}</div>
    <div class="ex-desc">${ex.desc}</div>
  </div>

  <div class="progress-bar"><div class="progress-fill" style="width:${pctDone}%"></div></div>

  <div class="code-block">
    <div class="code-header">
      <span>Análisis de Complejidad por Línea</span>
      <span style="color:var(--blue)">${answered}/${answerable.length} líneas respondidas</span>
    </div>
    <div class="code-lines-wrap">`;

  ex.lines.forEach((line, idx) => {
    let lineClass = 'code-line';
    let statusIcon = '';

    if (r.checked || r.revealed) {
      if (line.cx === null) {
        // no answer needed
      } else {
        const userAns = r.answers[idx];
        if (r.revealed) {
          lineClass += ' line-revealed';
        } else if (userAns === line.cx) {
          lineClass += ' line-correct';
          statusIcon = '<span class="line-status" style="color:var(--green)">✓</span>';
        } else {
          lineClass += ' line-wrong';
          statusIcon = '<span class="line-status" style="color:var(--red)">✗</span>';
        }
      }
    }

    html += `<div class="${lineClass}" id="codeline-${id}-${idx}">
      <span class="line-num">${idx+1}</span>
      <span class="line-code">${highlight(line.code)}</span>`;

    if (line.cx !== null) {
      const userAns = r.answers[idx];
      let tokenCls = userAns ? 'selected' : '';
      let tokenText = userAns || '— seleccionar —';

      if (r.checked || r.revealed) {
        if (r.revealed) {
          tokenCls = 'revealed-ans';
          tokenText = line.cx;
        } else if (userAns === line.cx) {
          tokenCls = 'correct';
          tokenText = userAns;
        } else {
          tokenCls = 'wrong';
          tokenText = userAns || '—';
        }
      }

      const disabled = (r.checked || r.revealed) ? 'disabled-sel' : '';
      html += `<div class="line-answer">
        <div class="token-selector" id="ts-${id}-${idx}">
          <div class="token-display ${tokenCls}" onclick="toggleDropdown('${id}','${idx}','${disabled}')">${tokenText}</div>
          <div class="token-dropdown" id="td-${id}-${idx}">`;
      TOKENS.forEach(t => {
        html += `<div class="token-opt" onclick="selectToken('${id}','${idx}','${t}')">${t}</div>`;
      });
      html += `</div></div>${statusIcon}</div>`;
    } else {
      html += `<div class="line-answer no-answer"></div>`;
    }

    html += `</div>`;
  });

  html += `</div></div>`; // end code-lines-wrap + code-block

  // Buttons
  const allAnswered = answerable.every((_, i) => {
    const li = ex.lines.indexOf(answerable[i]); // find real index
    const realIdx = ex.lines.findIndex((l,k) => l === answerable[i]);
    return r.answers[realIdx] !== undefined;
  });

  html += `<div class="btn-row">`;
  if (!r.checked && !r.revealed) {
    html += `<button class="btn btn-primary" onclick="checkAnswers(${id})">✓ Comprobar</button>`;
    html += `<button class="btn btn-secondary" onclick="resetExercise(${id})">↺ Reiniciar</button>`;
    html += `<button class="btn btn-warn" onclick="revealSolution(${id})">👁 Ver solución</button>`;
  } else {
    html += `<button class="btn btn-secondary" onclick="resetExercise(${id})">↺ Intentar de nuevo</button>`;
    if (!r.revealed) html += `<button class="btn btn-warn" onclick="revealSolution(${id})">👁 Ver solución completa</button>`;
  }
  html += `</div>`;

  // Result panel
  if (r.checked && !r.revealed) {
    const correctLines = answerable.filter((l,i) => {
      const realIdx = ex.lines.findIndex(ll=>ll===answerable[i]);
      return r.answers[realIdx] === l.cx;
    }).length;
    const pct = Math.round(correctLines/answerable.length*100);
    const color = pct===100 ? 'var(--green)' : pct>=60 ? 'var(--yellow)' : 'var(--red)';

    html += `<div class="result-panel show">
      <h3>📊 Resultado</h3>
      <div class="result-row"><span>Líneas correctas</span><span class="${pct===100?'result-correct':'result-wrong'}">${correctLines}/${answerable.length}</span></div>
      <div class="result-row"><span>Complejidad del algoritmo</span><span class="total-complexity">${ex.answer}</span></div>
      <div class="result-row"><span>Tu complejidad deducida</span><span style="color:${color}">${pct}% correcto</span></div>
    </div>`;
  }

  // Solution panel
  if (r.revealed) {
    html += `<div class="solution-panel show">
      <h3>👁 Solución completa</h3>`;
    ex.lines.forEach((line, idx) => {
      if (line.cx === null) return;
      html += `<div class="solution-line"><span style="color:var(--yellow)">${line.cx}</span> <span style="color:var(--muted)">→ línea ${idx+1}:</span> <span style="color:var(--text);font-size:.8rem">${line.code.trim()}</span></div>`;
      html += `<div class="solution-exp">${line.note}</div>`;
    });
    html += `<div style="margin-top:12px;padding:12px;background:var(--surface2);border-radius:6px;border-left:3px solid var(--yellow)">
      <div style="font-size:.75rem;color:var(--yellow);font-weight:600;margin-bottom:4px">COMPLEJIDAD TOTAL: ${ex.answer}</div>
      <div style="font-size:.8rem;color:var(--muted);line-height:1.6">${ex.explanation}</div>
    </div></div>`;
  }

  document.getElementById('exercise-view').innerHTML = html;
}

// ─────────────────────────────────────────
// DROPDOWN / MODAL LOGIC
// ─────────────────────────────────────────
// pending modal selection context
let modalCtx = null;

// Always use modal — works at any window width without breakpoint bugs
function toggleDropdown(exId, lineIdx, disabled) {
  if (disabled === 'disabled-sel') return;
  openTokenModal(exId, lineIdx);
}

function closeAllDropdowns() {
  // no-op kept for compatibility
}

// ── TOKEN MODAL (used at all sizes) ──
function openTokenModal(exId, lineIdx) {
  const ex = EXERCISES.find(e => e.id === parseInt(exId));
  if (!ex) return;
  const line = ex.lines[lineIdx];
  modalCtx = { exId, lineIdx };

  document.getElementById('token-modal-title').textContent = `Línea ${parseInt(lineIdx)+1} — elige la complejidad`;
  document.getElementById('token-modal-code').textContent = line.code.trim();

  const opts = document.getElementById('token-modal-opts');
  opts.innerHTML = TOKENS.map(t =>
    `<div class="token-modal-opt" onclick="selectTokenFromModal('${t}')">${t}</div>`
  ).join('');

  document.getElementById('token-modal-overlay').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function closeTokenModal() {
  document.getElementById('token-modal-overlay').classList.remove('open');
  document.body.style.overflow = '';
  modalCtx = null;
}

function handleModalOverlayClick(e) {
  if (e.target === document.getElementById('token-modal-overlay')) closeTokenModal();
}

function selectTokenFromModal(token) {
  if (!modalCtx) return;
  const { exId, lineIdx } = modalCtx;
  closeTokenModal();
  selectToken(exId, lineIdx, token);
}

function selectToken(exId, lineIdx, token) {
  const r = state.results[exId];
  if (!r || r.checked || r.revealed) return;
  r.answers[lineIdx] = token;
  closeAllDropdowns();
  renderExercise(parseInt(exId));
}

// ─────────────────────────────────────────
// CHECK / REVEAL / RESET
// ─────────────────────────────────────────
function checkAnswers(id) {
  const ex = EXERCISES.find(e=>e.id===id);
  const r = state.results[id];
  const answerable = ex.lines.filter(l => l.cx !== null);
  const allAnswered = answerable.every((l, i) => {
    const realIdx = ex.lines.findIndex(ll=>ll===answerable[i]);
    return r.answers[realIdx] !== undefined;
  });
  if (!allAnswered) {
    // allow partial check — just mark what's answered
  }
  const correctLines = answerable.filter((l,i) => {
    const realIdx = ex.lines.findIndex(ll=>ll===answerable[i]);
    return r.answers[realIdx] === l.cx;
  }).length;
  r.checked = true;
  r.correct = correctLines === answerable.length;
  updateStats();
  updateSidebarBtn(id);
  renderExercise(id);
}

function revealSolution(id) {
  const r = state.results[id];
  r.revealed = true;
  r.checked = false;
  r.correct = false;
  updateStats();
  updateSidebarBtn(id);
  renderExercise(id);
}

function resetExercise(id) {
  state.results[id] = { answers: {}, revealed: false, checked: false, correct: false };
  updateStats();
  updateSidebarBtn(id);
  renderExercise(id);
}

// ─────────────────────────────────────────
// INIT
// ─────────────────────────────────────────
buildSidebar();
updateStats();
</script>
</body>
</html>
